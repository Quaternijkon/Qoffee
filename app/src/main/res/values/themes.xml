<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Qoffee" parent="Theme.MaterialComponents.DayNight.NoActionBar" />
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <!-- Set the splash screen background, animated icon, and animation duration. -->
        <item name="windowSplashScreenBackground">@android:color/white</item>

        <!-- Use windowSplashScreenAnimatedIcon to add a drawable or an animated drawable. One of these is required. -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/slogan</item>
        
        <!-- set the theme of the Activity that follows your splash screen. This is required. -->
        <item name="postSplashScreenTheme">@style/Theme.Qoffee</item>
    </style>
</resources>
